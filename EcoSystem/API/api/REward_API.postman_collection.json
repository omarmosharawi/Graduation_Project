{
	"info": {
		"_postman_id": "reward-api-collection",
		"name": "REward API",
		"description": "API endpoints for REward recycling app - FCM notifications and ESP32 kiosk communication",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "https://yourdomain.com/api",
			"type": "string"
		},
		{
			"key": "apiKey",
			"value": "your-secret-api-key-change-this",
			"type": "string"
		},
		{
			"key": "testUserId",
			"value": "YOUR_USER_ID_HERE",
			"type": "string"
		},
		{
			"key": "testKioskId",
			"value": "YOUR_KIOSK_ID_HERE",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Health Check",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						""
					]
				}
			},
			"response": []
		},
		{
			"name": "Notifications",
			"item": [
				{
					"name": "Send OTP Email",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-API-Key",
								"value": "{{apiKey}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"test@example.com\",\n    \"otp\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/send-otp-email",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"send-otp-email"
							]
						}
					},
					"response": []
				},
				{
					"name": "Send to All Users (Topic)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"topic\": \"all_users\",\n    \"title\": \"New Announcement 📢\",\n    \"body\": \"Check out our new features!\",\n    \"data\": {\n        \"type\": \"announcement\"\n    }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/notify/topic",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"notify",
								"topic"
							]
						}
					},
					"response": []
				},
				{
					"name": "Send to New Offers Topic",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"topic\": \"offers_updates\",\n    \"title\": \"New Offer Available! 🎁\",\n    \"body\": \"50% off at Starbucks - only 100 points!\",\n    \"data\": {\n        \"type\": \"new_offer\"\n    }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/notify/topic",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"notify",
								"topic"
							]
						}
					},
					"response": []
				},
				{
					"name": "Send to Specific User",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"userId\": \"{{testUserId}}\",\n    \"title\": \"Hello! 👋\",\n    \"body\": \"This is a personal notification just for you.\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/notify/user",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"notify",
								"user"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Kiosk (ESP32)",
			"item": [
				{
					"name": "Get Kiosk Info",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/kiosk/{{testKioskId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"kiosk",
								"{{testKioskId}}"
							]
						}
					},
					"response": []
				},
				{
					"name": "Update Kiosk Status",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-API-Key",
								"value": "{{apiKey}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"available\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/kiosk/{{testKioskId}}/status",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"kiosk",
								"{{testKioskId}}",
								"status"
							]
						}
					},
					"response": []
				},
				{
					"name": "Submit Transaction (Earn Points)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-API-Key",
								"value": "{{apiKey}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"kioskId\": \"{{testKioskId}}\",\n    \"userId\": \"{{testUserId}}\",\n    \"plasticCount\": 3,\n    \"metalCount\": 2\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/kiosk/transaction",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"kiosk",
								"transaction"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "User",
			"item": [
				{
					"name": "Get User Info",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/user/{{testUserId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"user",
								"{{testUserId}}"
							]
						}
					},
					"response": []
				}
			]
		}
	]
}